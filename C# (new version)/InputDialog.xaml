<Window x:Class="LocalCallPro.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Profile"
        SizeToContent="Height"
        Width="380"
        MinHeight="160"
        Background="#1A1A2E"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="24,20,24,20">
        <TextBlock x:Name="TxtLabel"
                   Foreground="#CCCCCC" FontSize="13"
                   Margin="0,0,0,10"/>
        <Border Background="#252535" BorderBrush="#3A3A5E"
                BorderThickness="1" CornerRadius="6">
            <TextBox x:Name="TxtInput"
                     Background="Transparent" Foreground="#E0E0E0"
                     BorderThickness="0" CaretBrush="#BB86FC"
                     Padding="10,8" FontSize="14"
                     KeyDown="TxtInput_KeyDown"/>
        </Border>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Close" Width="90" Height="34" Margin="0,0,10,0"
                    Background="#252535" Foreground="#AAAAAA"
                    BorderBrush="#3A3A5E" BorderThickness="1"
                    Cursor="Hand" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#32324A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Save" Width="90" Height="34"
                    Background="#BB86FC" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    Click="OK_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9965E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
