<Window x:Class="LocalCallPro.GroupCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Group"
        SizeToContent="Height"
        Width="380" MinHeight="200"
        Background="#1A1A2E"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20,18,20,18">
        <TextBlock Text="Group name" Foreground="#888" FontSize="11" Margin="0,0,0,4"/>
        <Border Background="#252535" BorderBrush="#3A3A5E" BorderThickness="1" CornerRadius="6">
            <TextBox x:Name="TxtName" Background="Transparent" BorderThickness="0"
                     Foreground="#E0E0E0" CaretBrush="#BB86FC"
                     Padding="10,8" FontSize="14" KeyDown="TxtName_KeyDown"/>
        </Border>

        <TextBlock Text="Select members (pick at least 1)" Foreground="#888"
                   FontSize="11" Margin="0,14,0,6"/>
        <Border Background="#252535" BorderBrush="#3A3A5E" BorderThickness="1"
                CornerRadius="6" MaxHeight="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="FriendCheckList" Margin="4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                      IsChecked="{Binding IsSelected}"
                                      Foreground="#E0E0E0" FontSize="13"
                                      Margin="6,4" Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Width="90" Height="32" Margin="0,0,10,0"
                    Background="#252535" Foreground="#AAAAAA"
                    BorderBrush="#3A3A5E" BorderThickness="1" Cursor="Hand"
                    Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Create" Width="90" Height="32"
                    Background="#BB86FC" Foreground="White"
                    BorderThickness="0" Cursor="Hand" Click="Create_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#9965E8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
